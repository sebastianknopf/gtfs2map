GTFS_STATIC_URL=https://yourdomain.com/gtfs/static/data.zip

GTFS_REALTIME_METHOD=http

GTFS_REALTIME_HTTP_TRIP_UPDATES_URL=https://yourdomain.com/gtfs/realtime/trip-updates.pbf
GTFS_REALTIME_HTTP_VEHICLE_POSITIONS_URL=https://yourdomain.com/gtfs/realtime/vehicle-positions.pbf
GTFS_REALTIME_HTTP_SERVICE_ALERTS_URL=https://yourdomain.com/gtfs/realtime/service-alerts.pbf
GTFS_REALTIME_MQTT_BROKER_HOST=mqtt.yourdomain.com
GTFS_REALTIME_MQTT_BROKER_PORT=8084
GTFS_REALTIME_MQTT_BROKER_USERNAME=yourusername
GTFS_REALTIME_MQTT_BROKER_PASSWORD=yourpassword
GTFS_REALTIME_MQTT_TRIP_UPDATES_TOPIC=gtfs/realtime/trip-updates
GTFS_REALTIME_MQTT_VEHICLE_POSITIONS_TOPIC=gtfs/realtime/vehicle-positions
GTFS_REALTIME_MQTT_SERVICE_ALERTS_TOPIC=gtfs/realtime/service-alerts

APP_TEMPLATE_ID=default
APP_TEMPLATE_TITLE=gtfs2map
APP_TEMPLATE_COLOR="#03a535ff"
APP_DATETIME_FORMAT="DD.MM.YYYY HH:mm"
APP_DATE_FORMAT="DD.MM.YYYY"
APP_TIME_FORMAT="HH:mm"
APP_UNMATCHED_VEHICLES_ENABLED=true
APP_TEMPLATE_CREDITS=true