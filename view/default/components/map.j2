{% macro create(static_assets_dir, template_color, route_ids = none) %}
<script>
// create container for visual objects in the map
const vehicleMarkersMap = new Map();

// create initial map object and additional controls
const map = new maplibregl.Map({
    container: 'app-map',
    style: 'https://tiles.openfreemap.org/styles/positron',
    center: [10.5, 51.0],
    zoom: 8
});

map.addControl(new maplibregl.NavigationControl(), 'top-right');
map.addControl(new maplibregl.FullscreenControl(), 'top-right');

// add everything else when the map is loaded
map.on('load', function () {
    
    // add data sources
    {% if route_ids %}
    routesGeojson.features = routesGeojson.features.filter(f => {{ route_ids }}.includes(f.properties.route_id));
    
    map.addSource('routes', {
        type: 'geojson',
        data: routesGeojson
    });
    {% else %}
    map.addSource('routes', {
        type: 'geojson',
        data: routesGeojson
    });
    {% endif %}

    {% if route_ids %}
    stopsGeojson.features = stopsGeojson.features.filter(f => f.properties.routes.some(r => {{ route_ids }}.includes(r.route_id)));
    
    map.addSource('stops', {
        type: 'geojson',
        data: stopsGeojson
    });
    {% else %}
    map.addSource('stops', {
        type: 'geojson',
        data: stopsGeojson
    });
    {% endif %}

    // add layers for routes
    map.addLayer({
        'id': 'route-lines-outline',
        'type': 'line',
        'source': 'routes',
        'paint': {
            'line-color': '#ffffff',
            'line-width': 15
        },
        'layout': {
            'line-join': 'round',
            'line-cap': 'round'
        }
    });
    
    map.addLayer({
        'id': 'route-lines',
        'type': 'line',
        'source': 'routes',
        'paint': {
        'line-color': [
                'case',
                ['has', 'route_color'],
                ['get', 'route_color'],
                '{{ template_color }}'
            ],
            'line-width': 8
        },
        'layout': {
            'line-join': 'round',
            'line-cap': 'round'
        }
    });

    // add layer for stops
    map.addLayer({
        'id': 'stop-points',
        'type': 'circle',
        'source': 'stops',
        'minzoom': 14,
        'paint': {
            'circle-radius': 6,
            'circle-color': '#ccc',
            'circle-stroke-color': '#ffffff',
            'circle-stroke-width': 2          
        }
    });

    // fly to the bounds of all routes initially
    // if there's no vehicle which shall be focused
    let params = new URLSearchParams(window.location.search);
    let vehicleId = params.get('vehicleId');

    if (vehicleId == null || !vehicleMarkersMap.has(vehicleId)) {
        const bounds = getGeoJsonBounds(routesGeojson);
        map.fitBounds(bounds, {
            padding: 20,
            duration: 1000,
            easing(t) { return t; }
        });
    }
});

map.on('dragstart', function () {
    let params = new URLSearchParams(window.location.search);
    params.delete('vehicleId');

    window.history.replaceState({}, '', window.location.pathname + '?' + params);
});

map.on('zoom', function () {
    let zoom = map.getZoom();

    vehicleMarkersMap.forEach((marker, vehicleId) => {
        let markerElement = marker.getElement();

        let iconWrapper = markerElement.querySelector('.app-vehicle-img-wrapper');
        if (iconWrapper) {
            if (zoom < 14) {
                iconWrapper.style.transform = 'scale(0.6)';
            } else {
                iconWrapper.style.transform = '';
            }
        }

        let tripInfo = markerElement.querySelector('.app-vehicle-trip-info');
        if (tripInfo) {
            if (zoom < 14) {
                tripInfo.classList.add('hide-by-zoom');
            } else {
                tripInfo.classList.remove('hide-by-zoom');
            }
        }
    });
});

function routeVehiclePositionsCallback(positions) {

    // remove vehicle markers which are not present in the GTFS-RT vehicle positions anymore
    let vehicleIds = positions.map(p => p.vehicle.vehicle.id);
    for (const [vehicleId, marker] of vehicleMarkersMap.entries()) {
        if (!vehicleIds.includes(vehicleId)) {
            marker.remove();
            vehicleMarkersMap.delete(vehicleId);
        }
    }

    // update all vehicle positions with their latest incoming data    
    {% if APP_UNMATCHED_VEHICLES_ENABLED == false %}
    positions = filterVehiclePositions(positions, routeIds);
    {% endif %}

    positions.forEach(p => {
        if (vehicleMarkersMap.has(p.vehicle.vehicle.id)) {
            let marker = vehicleMarkersMap.get(p.vehicle.vehicle.id);

            let previousLngLat = marker.getLngLat();
            let thisLngLat = new maplibregl.LngLat(p.vehicle.position.longitude, p.vehicle.position.latitude);
            
            if (previousLngLat.lng != thisLngLat.lng || previousLngLat.lat != thisLngLat.lat) {
                marker.setLngLat([thisLngLat.lng, thisLngLat.lat]);

                let bearing = this.getVehicleBearing(previousLngLat, thisLngLat);
                let markerVehicleDirection = marker.getElement().querySelector('.app-vehicle-direction-arrow-wrapper');
                if (markerVehicleDirection) {
                    markerVehicleDirection.style.transform = `translate(-50%, -50%) rotate(${bearing}deg)`
                } else {
                    console.log('Not Found');
                }
            }

            let vehicleTripId = p.vehicle.trip != null ? p.vehicle.trip.trip_id : null;
            if (vehicleTripId && window.tripUpdates) {
                let tripUpdate = window.tripUpdates.find(u => u.trip_update.trip.trip_id == vehicleTripId);
                if (tripUpdate) {
                    updateVehicleMarkerTripData(marker.getElement(), tripUpdate, p);
                }
            }
        } else {
            let markerContainer = createVehicleMarkerContainer(p, '{{ static_assets_dir }}');

            let marker = new maplibregl.Marker({
                    element: markerContainer, 
                    anchor: 'center'
                })
                .setLngLat([p.vehicle.position.longitude, p.vehicle.position.latitude])
                .addTo(map);

            marker.getElement().addEventListener('click', function () {
                let params = new URLSearchParams(window.location.search);
                params.set('vehicleId', p.vehicle.vehicle.id);

                window.history.replaceState({}, '', window.location.pathname + '?' + params);

                map.flyTo({
                    center: marker.getLngLat(),
                    zoom: 16
                });
            });

            let vehicleTripId = p.vehicle.trip != null ? p.vehicle.trip.trip_id : null;
            if (vehicleTripId && window.tripUpdates) {
                let tripUpdate = window.tripUpdates.find(u => u.trip_update.trip.trip_id == vehicleTripId);
                if (tripUpdate) {
                    updateVehicleMarkerTripData(marker.getElement(), tripUpdate, p);
                }
            }

            vehicleMarkersMap.set(p.vehicle.vehicle.id, marker);
        }
    });

    // if we have set a certain vehicleId in URL params
    // try to select the corresponding marker and fly map to this vehicle
    let params = new URLSearchParams(window.location.search);
    let vehicleId = params.get('vehicleId');
    
    if (vehicleMarkersMap.has(vehicleId)) {
        let vehicleMarker = vehicleMarkersMap.get(vehicleId);

        map.easeTo({
            center: vehicleMarker.getLngLat(),
            zoom: 16
        });
    }
}
</script>
{% endmacro %}