{% macro create(static_assets_dir) %}
<div id="app-vehicle-info-dialog" class="w3-card w3-padding w3-white w3-hide">
    <div class="app-vehicle-info-dialog-wrapper" id="app-vehicle-info-matched">
        <div>
            <div class="w3-large app-route-name" id="app-vehicle-info-route-name">720</div>
        </div>
        <div>
            <span class="w3-large" id="app-vehicle-info-trip-headsign">FinalStopName</span>
        </div>
        <div id="app-vehicle-info-dialog-close" onclick="hideVehicleInfoDialog();">
            <span class="w3-text-gray w3-bold">&#x2715;</span>
        </div>
    </div>
    <div class="app-vehicle-info-dialog-wrapper w3-hide" id="app-vehicle-info-unmatched">
        <div>
            <img src="{{ static_assets_dir }}/img/realtime.svg" width="32" height="32" />
        </div>
        <div>
            <span class="w3-large" id="app-vehicle-info-vehicle-label">TE-ST4</span>
        </div>
        <div id="app-vehicle-info-dialog-close" onclick="hideVehicleInfoDialog();">
            <span class="w3-text-gray w3-bold">&#x2715;</span>
        </div>
    </div>
    <div class="app-vehicle-info-dialog-row" id="app-vehicle-info-next-stop">
        <span class="app-vehicle-info-dialog-label w3-padding-16">Nächster Halt:</span>
        <span class="app-vehicle-info-dialog-label w3-padding-16 w3-bold" id="app-vehicle-info-next-stop-name">%StopName%</span>
        <span class="app-vehicle-info-dialog-label w3-padding-16"> in </span>
        <span class="app-vehicle-info-dialog-label w3-padding-16" id="app-vehicle-info-next-stop-duration">%Duration%</span>
    </div>
    <div class="app-vehicle-info-dialog-row">
        <span class="app-vehicle-info-dialog-label w3-text-gray">Letztes Update vor</span>
        <span class="app-vehicle-info-dialog-label w3-text-gray" id="app-vehicle-info-last-update-seconds">%LastUpdateSeconds%</span>
    </div>
</div>
{% endmacro %}