var routesGeojson = {{ routes|geojson }};
var stopsGeojson = {{ stops|geojson }};

var tripUpdates = [];
var vehiclePositions = [];
let realtimeUpdateInterval;

var serviceAlerts = [];
let serviceAlertsUpdateInterval;

function escapeId(id) {
  return id
    .replace(/\\/g, '_')
    .replace(/\//g, '_')
    .replace(/&/g, '_')
    .replace(/%/g, '_')
    .replace(/:/g, '_')
    .replace(/\?/g, '_')
    .replace(/#/g, '_')
    .replace(/"/g, '_');
}

