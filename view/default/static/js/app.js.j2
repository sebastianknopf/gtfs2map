var serviceAlerts = [];
let serviceAlertsUpdateInterval;

function escapeId(id) {
  return id
    .replace(/\\/g, '_')
    .replace(/\//g, '_')
    .replace(/&/g, '_')
    .replace(/%/g, '_')
    .replace(/:/g, '_')
    .replace(/\?/g, '_')
    .replace(/#/g, '_')
    .replace(/"/g, '_');
}

