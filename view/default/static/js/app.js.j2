function updateVehicleMarkerTripData(container, tripUpdate, vehiclePosition) {
    let tripInfoDiv = container.querySelector('.app-vehicle-trip-info');
    if (tripInfoDiv) {
        if (tripUpdate) {
            let routeNameSpan = tripInfoDiv.querySelector('.app-trip-info-route-name');
            if (routeNameSpan) {
                let routeProperties = getRouteProperties(tripUpdate.trip_update.trip.route_id);
                if (routeProperties && routeProperties.route_short_name != null) {
                    routeNameSpan.innerHTML = `<b>${routeProperties.route_short_name}</b>`;
                } else if (routeProperties && routeProperties.route_long_name != null) {
                    routeNameSpan.innerHTML = `<b>${routeProperties.route_long_name}</b>`;
                }

                if (routeProperties) 
                {
                    routeNameSpan.style.background = routeProperties.route_color || '{{ APP_TEMPLATE_COLOR }}';
                    routeNameSpan.style.color = routeProperties.route_text_color || '{{ APP_TEMPLATE_COLOR|text(0) }}';
                }
            }

            let delayInfoSpan = tripInfoDiv.querySelector('.app-trip-info-delay');
            if (delayInfoSpan) {
                // assume that the first stopTimeUpdate in the tripUpdate is the next stop
                // if our vehicle position has a stop_id and current_stop_sequence, use this to pick the correct stopTimeUpdate
                let stopTimeUpdate = tripUpdate.trip_update.stop_time_update[0];
                if (vehiclePosition.vehicle.stop_id != null && vehiclePosition.vehicle.current_stop_sequence != null) {
                    let stopTimeUpdateOverride = tripUpdate.trip_update.stop_time_update.find(s => s.stop_id == vehiclePosition.vehicle.stop_id && (s.stop_sequence == 0 || s.stop_sequence == vehiclePosition.vehicle.stop_sequence));
                    if (stopTimeUpdateOverride) {
                        stopTimeUpdate = stopTimeUpdateOverride;
                    }
                }

                if (stopTimeUpdate && (stopTimeUpdate.departure.delay != null || stopTimeUpdate.arrival.delay != null)) {
                    let delayMinutes = getDelayMinutes(stopTimeUpdate.departure.delay || stopTimeUpdate.arrival.delay);

                    if (delayMinutes >= 0) {
                        delayInfoSpan.innerHTML = `<b>+${delayMinutes}</b>`;
                    } else {
                        delayInfoSpan.innerHTML = `<b>${delayMinutes}</b>`;
                    }

                    delayInfoSpan.style.background = '#ffffff';
                    if (Math.abs(delayMinutes) < 3 && delayMinutes >= 0) {
                        delayInfoSpan.style.color = '#00b700ff';
                    } else {
                        delayInfoSpan.style.color = '#ff0000ff';
                    }
                }
            }

            tripInfoDiv.classList.remove('w3-hide');
        } else {
            tripInfoDiv.classList.add('w3-hide');
        }
    }
}

function filterServiceAlerts(alerts, routeId) {
    let routeStopIds = stopsGeojson.features.filter(f => f.properties.routes.some(r => r.route_id == routeId)).map(f => f.properties.stop_id);
    let routeParentStationIds = [...new Set(stopsGeojson.features.filter(f => f.properties.routes.some(r => r.route_id == routeId)).map(f => f.properties.parent_station))];

    return alerts.filter(a => {
        if (!a.alert.informed_entity) {
            return true;
        }

        return a.alert.informed_entity.some(e => e.route_id === routeId) || 
            a.alert.informed_entity.some(e => routeStopIds.includes(e.stop_id)) ||
            a.alert.informed_entity.some(e => routeParentStationIds.includes(e.stop_id));
    });
}

async function updateServiceAlerts(url, routeIds, serviceAlertsCallback) {
    let alerts = await fetchGtfsRealtimeData(url, null);
    let routeServiceAlertsMap = new Map();

    window.serviceAlerts = [];

    routeIds.forEach(r => {
        let serviceAlertsForRoute = filterServiceAlerts(alerts, r);
        routeServiceAlertsMap.set(r, serviceAlertsForRoute);

        window.serviceAlerts += serviceAlertsForRoute;
    });

    if (serviceAlertsCallback) {
        serviceAlertsCallback(routeServiceAlertsMap);
    }
}

function initializeHttpServiceAlerts(url, routeIds, serviceAlertsCallback) {
    if (!serviceAlertsUpdateInterval) {
        const updateInterval = 60 * 1000;

        updateServiceAlerts(url, routeIds, serviceAlertsCallback);

        serviceAlertsUpdateInterval = setInterval(() => {
            updateServiceAlerts(url, routeIds, serviceAlertsCallback);
        }, updateInterval);
    }
}

function createAlertContainer(alertObject) {
    const alertContainer = document.createElement('div');
    
    const alertTitle = document.createElement('h6');
    alertTitle.innerHTML = getTranslation(alertObject.alert.header_text.translation, 'de');
    alertContainer.appendChild(alertTitle);

    alertObject.alert.active_period.forEach(p => {
        const activePeriodParagraph = document.createElement('p');
        activePeriodParagraph.classList.add('w3-small');
        activePeriodParagraph.classList.add('w3-bold');
        
        if (p.start != 0 && p.end != 0) {
            activePeriodParagraph.innerHTML = `Von ${moment.unix(p.start).format('{{ APP_DATETIME_FORMAT }}')} bis ${moment.unix(p.end).format('{{ APP_DATETIME_FORMAT }}')}`;
            alertContainer.appendChild(activePeriodParagraph);
        } else if (p.start != 0 && p.end == 0) {
            activePeriodParagraph.innerHTML = `Ab ${moment.unix(p.start).format('{{ APP_DATETIME_FORMAT }}')}`;
            alertContainer.appendChild(activePeriodParagraph);
        } else if (p.start == 0 && p.end != 0) {
            activePeriodParagraph.innerHTML = `Bis ${moment.unix(p.end).format('{{ APP_DATETIME_FORMAT }}')}`;
            alertContainer.appendChild(activePeriodParagraph);
        } 
    });

    const alertMessage = document.createElement('p');
    alertMessage.classList.add('w3-text-gray');
    alertMessage.classList.add('w3-small');
    alertMessage.innerHTML = getTranslation(alertObject.alert.description_text.translation, 'de');
    alertContainer.appendChild(alertMessage);

    const alertLink = document.createElement('a');
    alertLink.setAttribute('href', getTranslation(alertObject.alert.url.translation, 'de'));
    alertLink.setAttribute('target', '_blank');
    alertLink.classList.add('w3-text-theme');
    alertLink.classList.add('w3-small');
    alertLink.innerHTML = 'Mehr Infos';
    alertContainer.appendChild(alertLink);

    return alertContainer;
}