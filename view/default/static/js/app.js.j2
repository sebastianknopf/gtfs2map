var routesGeojson = {{ routes|geojson }};
var stopsGeojson = {{ stops|geojson }};

var tripUpdates = [];
var vehiclePositions = [];
let realtimeUpdateInterval;
let vehicleInfoLastUpdateTimeout;

var serviceAlerts = [];
let serviceAlertsUpdateInterval;

var vehicleMarkersMap = new Map();

let appZoomLevel = 0;

function escapeId(id) {
  return id
    .replace(/\\/g, '_')
    .replace(/\//g, '_')
    .replace(/&/g, '_')
    .replace(/%/g, '_')
    .replace(/:/g, '_')
    .replace(/\?/g, '_')
    .replace(/#/g, '_')
    .replace(/"/g, '_');
}

function clearUrlParameters() {
    let params = new URLSearchParams(window.location.search);
    params.delete('vehicleId');

    window.history.replaceState({}, '', window.location.pathname + '?' + params);
}

function showMenu() {
	document.getElementById('app-menu').classList.remove('w3-hide-small');
	document.getElementById('app-menu').classList.remove('w3-hide-medium');
	
	document.getElementById('app-action-open-menu').classList.add('w3-hide');
	document.getElementById('app-action-close-menu').classList.remove('w3-hide');
}
 
function hideMenu() {
	document.getElementById('app-menu').classList.add('w3-hide-small');
	document.getElementById('app-menu').classList.add('w3-hide-medium');
	
	document.getElementById('app-action-open-menu').classList.remove('w3-hide');
	document.getElementById('app-action-close-menu').classList.add('w3-hide');
}

function showVehicleInfoDialog(vehicleId) {    

    let tripUpdate = findTripUpdate(vehicleId);
    let vehiclePosition = findVehiclePosition(vehicleId);
    if (vehiclePosition == null) {
        return;
    }

    let currentTimestamp = Math.floor(Date.now() / 1000);
    let lastUpdateSeconds = currentTimestamp - vehiclePosition.vehicle.timestamp;

    let route = null;
    let nextStop = null;
    if (tripUpdate != null) {
        let routeProperties = getRouteProperties(tripUpdate.trip_update.trip.route_id);
        let nextStopProperties = getStopProperties(tripUpdate.trip_update.stop_time_update[0].stop_id);
        let lastStopProperties = getStopProperties(tripUpdate.trip_update.stop_time_update[tripUpdate.trip_update.stop_time_update.length - 1].stop_id);

        route = {
            shortName: routeProperties.route_short_name != null ? routeProperties.route_short_name : routeProperties.route_long_name,
            color: routeProperties.route_color,
            textColor: routeProperties.route_text_color,
            directionText: lastStopProperties.stop_name
        };

        nextStop = {
            stopName: nextStopProperties.stop_name,
            arrivalTimestamp: tripUpdate.trip_update.stop_time_update[0].arrival != null ? tripUpdate.trip_update.stop_time_update[0].arrival.time : tripUpdate.trip_update.stop_time_update[0].departure.time
        };
    }
    
    if (route != null && nextStop != null) {
        let durationToArrival = Math.max(Math.round(((nextStop.arrivalTimestamp - currentTimestamp) / 60.0) / 0.5) * 0.5, 0);
        
        let routeName = document.getElementById('app-vehicle-info-route-name');
        routeName.textContent = route.shortName;
        routeName.style.background = route.color;
        routeName.style.color = route.textColor;
        routeName.style.background = route.color || '{{ APP_TEMPLATE_COLOR }}';
        routeName.style.color = route.textColor || '{{ APP_TEMPLATE_COLOR|text(0) }}';

        document.getElementById('app-vehicle-info-trip-headsign').textContent = route.directionText;
        document.getElementById('app-vehicle-info-next-stop-name').textContent = nextStop.stopName;
        document.getElementById('app-vehicle-info-next-stop-duration').textContent = durationToArrival + "min";

        document.getElementById('app-vehicle-info-next-stop').classList.remove('w3-hide');
        document.getElementById('app-vehicle-info-matched').classList.remove('w3-hide');
        document.getElementById('app-vehicle-info-unmatched').classList.add('w3-hide');
    } else {
        document.getElementById('app-vehicle-info-vehicle-label').textContent = vehiclePosition.vehicle.vehicle.label != null ? vehiclePosition.vehicle.vehicle.label : vehiclePosition.vehicle.vehicle.id;

        document.getElementById('app-vehicle-info-next-stop').classList.add('w3-hide');
        document.getElementById('app-vehicle-info-matched').classList.add('w3-hide');
        document.getElementById('app-vehicle-info-unmatched').classList.remove('w3-hide');
    }

    if (vehicleInfoLastUpdateTimeout) {
        clearTimeout(vehicleInfoLastUpdateTimeout);
    }

    function updateLastUpdateSeconds() {
        let displayValue;
        if (lastUpdateSeconds < 60) {
            displayValue = lastUpdateSeconds + "s";
        } else if (lastUpdateSeconds < 3600) {
            displayValue = Math.round(lastUpdateSeconds / 60.0) + "min";
        } else {
            displayValue = Math.round(lastUpdateSeconds / 3600.0) + "h";
        }

        document.getElementById('app-vehicle-info-last-update-seconds').textContent = displayValue;

        lastUpdateSeconds += 1;
        vehicleInfoLastUpdateTimeout = setTimeout(updateLastUpdateSeconds, 1000);
    }
    updateLastUpdateSeconds();
    
    document.getElementById('app-vehicle-info-dialog').classList.remove('w3-hide');
}

function hideVehicleInfoDialog() {
    clearUrlParameters();
    if (vehicleInfoLastUpdateTimeout) {
        clearTimeout(vehicleInfoLastUpdateTimeout);
        vehicleInfoLastUpdateTimeout = null;
    }
    document.getElementById('app-vehicle-info-dialog').classList.add('w3-hide');
}

function onRouteItemClick(routeId) {
    window.location.href = `${routeId}.html`;
}

function getGeoJsonBounds(geojson) {
    const bounds = new maplibregl.LngLatBounds();
	
    geojson.features.forEach(feature => {
        const geom = feature.geometry;
        if (geom.type === 'LineString') {
            geom.coordinates.forEach(coord => bounds.extend(coord));
        } else if (geom.type === 'MultiLineString') {
            geom.coordinates.forEach(line => line.forEach(coord => bounds.extend(coord)));
        }
    });

    return bounds;
}

function getRouteProperties(routeId) {
    let routeFeature = routesGeojson.features.find(r => r.properties.route_id == routeId);
    if (routeFeature) {
        return routeFeature.properties;
    } else {
        return null;
    }
}

function getStopProperties(stopId) {
    let stopFeature = stopsGeojson.features.find(s => s.properties.stop_id == stopId);
    if (stopFeature) {
        return stopFeature.properties;
    } else {
        return null;
    }
}

function getDelayMinutes(delaySeconds) {
    let delayMinutes = delaySeconds / 60.0;
    let roundedDelay = Math.round(delayMinutes / 0.5) * 0.5;
    
    return Number(roundedDelay.toFixed(1));
}

function getVehicleBearing(lngLatA, lngLatB) {
    const lat1 = lngLatA.lat;
    const lon1 = lngLatA.lng;
    const lat2 = lngLatB.lat;
    const lon2 = lngLatB.lng;

    const y = Math.sin(lon2 - lon1) * Math.cos(lat2);
    const x = Math.cos(lat1) * Math.sin(lat2) - Math.sin(lat1) * Math.cos(lat2) * Math.cos(lon2 - lon1);
    
    let bearing = (Math.atan2(y, x) * 180) / Math.PI;
    bearing = (bearing + 360) % 360;

    return bearing
}

function getTranslation(translations, language) {
    let translation = translations.find(t => t.language.startsWith(language));
    if (translation) {
        return translation.text;
    } else if (translations.length > 0) {
        return translations[0].text;
    } else {
        return null;
    }
}

function setAppZoomLevel(zoom) {
    appZoomLevel = zoom;
    applyVisualAppStyles();
}

function applyVisualAppStyles() {
    vehicleMarkersMap.forEach((marker, vehicleId) => {
        let markerElement = marker.getElement();

        let iconWrapper = markerElement.querySelector('.app-vehicle-img-wrapper');
        if (iconWrapper) {
            if (appZoomLevel < 14) {
                iconWrapper.style.transform = 'translateX(-50%) scale(0.6)';
                iconWrapper.style.transformOrigin = 'center center';
            } else {
                iconWrapper.style.transform = '';
                iconWrapper.style.transformOrigin = '';
            }
        }

        let tripInfo = markerElement.querySelector('.app-vehicle-trip-info');
        if (tripInfo) {
            if (appZoomLevel < 14) {
                tripInfo.classList.add('hide-by-zoom');
            } else {
                tripInfo.classList.remove('hide-by-zoom');
            }
        }
    });
}

function initializeMqttRealtimeUpdates(mqttBrokerHost, mqttBrokerPort, mqttBrokerUsername, mqttBrokerPassword, tripUpdatesTopic, tripUpdatesCallback, vehiclePositionsTopic, vehiclePositionsCallback, serviceAlertsTopic, serviceAlertsCallback, routeIds) {
    window.tripUpdates = [];
    window.vehiclePositions = [];
    window.serviceAlerts = [];
    
    client = mqtt.connect(`wss://${mqttBrokerHost}:${mqttBrokerPort}/mqtt`, {
            username: mqttBrokerUsername,
            password: mqttBrokerPassword
    });

    client.on('connect', () => {
        if (tripUpdatesTopic != null) {
            client.subscribe(tripUpdatesTopic);
        }

        if (vehiclePositionsTopic != null) {
            client.subscribe(vehiclePositionsTopic);
        }

        if (serviceAlertsTopic != null) {
            client.subscribe(serviceAlertsTopic);
        }
    });

    client.on('message', (topic, message) => {
        const protocolBuffer = new Pbf(new Uint8Array(message));
        const obj = FeedMessage.read(protocolBuffer);

        for (let entity of obj.entity) {
            if (entity.vehicle != undefined) {
                window.vehiclePositions = window.vehiclePositions.filter(
                    e => e.id != entity.id
                );

                if (!entity.is_deleted) {
                    window.vehiclePositions.push(entity);
                }

                if (vehiclePositionsCallback) {
                    vehiclePositionsCallback(window.vehiclePositions);
                }
            } else if (entity.trip_update != undefined) {
                window.tripUpdates = window.tripUpdates.filter(
                    e => e.id != entity.id
                );

                if (!entity.is_deleted) {
                    window.tripUpdates.push(entity);                
                }

                if (tripUpdatesCallback) {
                    tripUpdatesCallback(window.tripUpdates);
                }
            } else if (entity.alert != undefined) {
                window.serviceAlerts = window.serviceAlerts.filter(
                    e => e.id != entity.id
                );

                if (!entity.is_deleted) {
                    window.serviceAlerts.push(entity);                
                }
                
                let routeServiceAlertsMap = new Map();
                routeIds.forEach(r => {
                    let serviceAlertsForRoute = filterServiceAlerts(window.serviceAlerts, r);
                    routeServiceAlertsMap.set(r, serviceAlertsForRoute);
                });

                if (serviceAlertsCallback) {
                    serviceAlertsCallback(routeServiceAlertsMap);
                }
            }
        }
    });

    // run initial callback for service alerts in order to show empty message
    let routeServiceAlertsMap = new Map();
    routeIds.forEach(r => {
        let serviceAlertsForRoute = filterServiceAlerts(window.serviceAlerts, r);
        routeServiceAlertsMap.set(r, serviceAlertsForRoute);
    });

    if (serviceAlertsCallback) {
        serviceAlertsCallback(routeServiceAlertsMap);
    }
}

async function fetchGtfsRealtimeData(url, headers) {
    if (!url) {
        return null;
    }

    const response = await fetch(url, {
        headers: { ...(headers ?? {}) },
    });

    if (!response.ok) {
        throw new Error(response.status);
    }

    const arrayBuffer = await response.arrayBuffer();
    const protocolBuffer = new Pbf(new Uint8Array(arrayBuffer));
    const obj = FeedMessage.read(protocolBuffer);

    return obj.entity;
}

function filterTripUpdates(updates, routeIds) {
    return updates.filter(u => {
        if (u.trip_update.trip == null) {
            return false;
        }

        return u.trip_update.trip != null && routeIds.includes(u.trip_update.trip.route_id);
    });
}

async function updateTripUpdates(url, routeIds, tripUpdatesCallback) {
    let updates = await fetchGtfsRealtimeData(url, null);

    window.tripUpdates = filterTripUpdates(updates, routeIds);

    if (tripUpdatesCallback) {
        tripUpdatesCallback(window.tripUpdates);
    }
}

function findTripUpdate(vehicleId) {
    return window.tripUpdates.find(u => u.trip_update.vehicle != null && u.trip_update.vehicle.id == vehicleId);
}

function filterVehiclePositions(positions, routeIds) {
    return positions.filter(p => {
        if (p.vehicle.trip == null) {
            return false;
        }

        return p.vehicle.trip.route_id != null && routeIds.includes(p.vehicle.trip.route_id);
    });
}

async function updateVehiclePositions(url, routeIds, vehiclePositionsCallback) {
    let positions = await fetchGtfsRealtimeData(url, null);

    window.vehiclePositions = positions.filter(p => {
        return p.vehicle.vehicle != null && p.vehicle.vehicle.id != null;
    });

    if (vehiclePositionsCallback) {
        vehiclePositionsCallback(window.vehiclePositions);
    }
}

function findVehiclePosition(vehicleId) {
    return window.vehiclePositions.find(p => p.vehicle.vehicle.id == vehicleId);
}

async function initializeHttpRealtimeUpdates(tripUpdatesUrl, tripUpdatesCallback, vehiclePositionsUrl, vehiclePositionsCallback, routeIds) {
    if (!realtimeUpdateInterval) {
        const updateInterval = 10 * 1000;

        await updateTripUpdates(tripUpdatesUrl, routeIds, tripUpdatesCallback);
        await updateVehiclePositions(vehiclePositionsUrl, routeIds, vehiclePositionsCallback);

        realtimeUpdateInterval = setInterval(async () => {
            await updateTripUpdates(tripUpdatesUrl, routeIds, tripUpdatesCallback);
            await updateVehiclePositions(vehiclePositionsUrl, routeIds, vehiclePositionsCallback);
        }, updateInterval);
    }
}

