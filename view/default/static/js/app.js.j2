	document.getElementById('app-action-open-menu').classList.add('w3-hide');
	document.getElementById('app-action-close-menu').classList.remove('w3-hide');
}
 
function hideMenu() {
	document.getElementById('app-menu').classList.add('w3-hide-small');
	document.getElementById('app-menu').classList.add('w3-hide-medium');
	
	document.getElementById('app-action-open-menu').classList.remove('w3-hide');
	document.getElementById('app-action-close-menu').classList.add('w3-hide');
}

function onRouteItemClick(routeId) {
    window.location.href = `routes/${routeId}.html`;
}

function getGeoJsonBounds(geojson) {
    const bounds = new maplibregl.LngLatBounds();
	
    geojson.features.forEach(feature => {
        const geom = feature.geometry;
        if (geom.type === 'LineString') {
            geom.coordinates.forEach(coord => bounds.extend(coord));
        } else if (geom.type === 'MultiLineString') {
            geom.coordinates.forEach(line => line.forEach(coord => bounds.extend(coord)));
        }
    });

    return bounds;
}

function getRouteProperties(routeId) {
    let routeFeature = routesGeojson.features.find(r => r.properties.route_id == routeId);
    if (routeFeature) {
        return routeFeature.properties;
    } else {
        return null;
    }
}

function getStopProperties(stopId) {
    let stopFeature = stopsGeojson.features.find(s => s.properties.stop_id == stopId);
    if (stopFeature) {
        return stopFeature.properties;
    } else {
        return null;
    }
}

function getDelayMinutes(delaySeconds) {
    let delayMinutes = delaySeconds / 60.0;

    return Math.round(delayMinutes / 0.1) * 0.1;
}

function getVehicleBearing(lngLatA, lngLatB) {
    const lat1 = lngLatA.lat;
    const lon1 = lngLatA.lng;
    const lat2 = lngLatB.lat;
    const lon2 = lngLatB.lng;

    const y = Math.sin(lon2 - lon1) * Math.cos(lat2);
    const x = Math.cos(lat1) * Math.sin(lat2) - Math.sin(lat1) * Math.cos(lat2) * Math.cos(lon2 - lon1);
    
    let bearing = (Math.atan2(y, x) * 180) / Math.PI;
    bearing = (bearing + 360) % 360;

    return bearing
}

function getTranslation(translations, language) {
    let translation = translations.find(t => t.language.startsWith(language));
    if (translation) {
        return translation.text;
    } else if (translations.length > 0) {
        return translations[0].text;
    } else {
        return null;
    }
}

async function fetchGtfsRealtimeData(url, headers) {
    if (!url) {
        return null;
    }

    const response = await fetch(url, {
        headers: { ...(headers ?? {}) },
    });

    if (!response.ok) {
        throw new Error(response.status);
    }

    const arrayBuffer = await response.arrayBuffer();
    const protocolBuffer = new Pbf(new Uint8Array(arrayBuffer));
    const obj = FeedMessage.read(protocolBuffer);

    return obj.entity;
}

function filterTripUpdates(updates, routeIds) {
    return updates.filter(u => {
        if (u.trip_update.trip == null) {
            return false;
        }

        return u.trip_update.trip != null && routeIds.includes(u.trip_update.trip.route_id);
    });
}

async function updateTripUpdates(url, routeIds, tripUpdatesCallback) {
    let updates = await fetchGtfsRealtimeData(url, null);

    window.tripUpdates = filterTripUpdates(updates, routeIds);

    if (tripUpdatesCallback) {
        tripUpdatesCallback(window.tripUpdates);
    }
}

function filterVehiclePositions(positions, routeIds) {
    return positions.filter(p => {
        if (p.vehicle.trip == null) {
            return false;
        }

        return p.vehicle.trip.route_id != null && routeIds.includes(p.vehicle.trip.route_id);
    });
}

async function updateVehiclePositions(url, routeIds, vehiclePositionsCallback) {
    let positions = await fetchGtfsRealtimeData(url, null);

    window.vehiclePositions = positions.filter(p => {
        return p.vehicle.vehicle != null && p.vehicle.vehicle.id != null;
    });

    if (vehiclePositionsCallback) {
        vehiclePositionsCallback(window.vehiclePositions);
    }
}

async function initializeRealtimeUpdates(tripUpdatesUrl, tripUpdatesCallback, vehiclePositionsUrl, vehiclePositionsCallback, routeIds) {
    if (!realtimeUpdateInterval) {
        const updateInterval = 10 * 1000;

        await updateTripUpdates(tripUpdatesUrl, routeIds, tripUpdatesCallback);
        await updateVehiclePositions(vehiclePositionsUrl, routeIds, vehiclePositionsCallback);

        realtimeUpdateInterval = setInterval(async () => {
            await updateTripUpdates(tripUpdatesUrl, routeIds, tripUpdatesCallback);
            await updateVehiclePositions(vehiclePositionsUrl, routeIds, vehiclePositionsCallback);
        }, updateInterval);
    }
}

